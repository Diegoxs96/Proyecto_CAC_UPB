<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<TitledPane animated="false"
            maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="600.0"
            text="UPB-CAC — Registro"
            fx:controller="edu.co.diegoxs96.Client.Controller.RegistrerController"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1">
  <content>
    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="380.0" prefWidth="600.0">
      <children>
        <!-- Identificación -->
        <Label layoutX="116.0" layoutY="35.0" prefHeight="30.0" prefWidth="166.0"
               text="Identificación" textAlignment="CENTER">
          <font><Font size="15.0"/></font>
        </Label>
        <TextField fx:id="fieldIdentificacion" layoutX="107.0" layoutY="63.0"
                   prefHeight="26.0" prefWidth="183.0"
                   style="-fx-background-color: #bdbdbd;"
                   promptText="Número de ID"/>

        <!-- Correo -->
        <Label layoutX="321.0" layoutY="35.0" prefHeight="30.0" prefWidth="166.0"
               text="Correo Electrónico" textAlignment="CENTER">
          <font><Font size="15.0"/></font>
        </Label>
        <TextField fx:id="fieldCorreo" layoutX="313.0" layoutY="63.0"
                   prefHeight="26.0" prefWidth="183.0"
                   style="-fx-background-color: #bdbdbd;"
                   promptText="correo@gmail.com"/>

        <!-- Nombres -->
        <Label layoutX="116.0" layoutY="95.0" prefHeight="30.0" prefWidth="166.0"
               text="Nombres" textAlignment="CENTER">
          <font><Font size="15.0"/></font>
        </Label>
        <TextField fx:id="fieldNombres" layoutX="107.0" layoutY="119.0"
                   prefHeight="26.0" prefWidth="183.0"
                   style="-fx-background-color: #bdbdbd;"
                   promptText="Nombres"/>

        <!-- Apellidos -->
        <Label layoutX="321.0" layoutY="95.0" prefHeight="30.0" prefWidth="166.0"
               text="Apellidos" textAlignment="CENTER">
          <font><Font size="15.0"/></font>
        </Label>
        <TextField fx:id="fieldApellidos" layoutX="313.0" layoutY="119.0"
                   prefHeight="26.0" prefWidth="183.0"
                   style="-fx-background-color: #bdbdbd;"
                   promptText="Apellidos"/>

        <!-- Edad -->
        <Label layoutX="116.0" layoutY="156.0" prefHeight="30.0" prefWidth="166.0"
               text="Edad" textAlignment="CENTER">
          <font><Font size="15.0"/></font>
        </Label>
        <TextField fx:id="fieldEdad" layoutX="107.0" layoutY="180.0"
                   prefHeight="26.0" prefWidth="183.0"
                   style="-fx-background-color: #bdbdbd;"
                   promptText="Edad"/>

        <!-- Contraseña -->
        <Label layoutX="321.0" layoutY="156.0" prefHeight="30.0" prefWidth="166.0"
               text="Contraseña" textAlignment="CENTER">
          <font><Font size="15.0"/></font>
        </Label>
        <TextField fx:id="fieldContrasena" layoutX="313.0" layoutY="180.0"
                   prefHeight="26.0" prefWidth="183.0"
                   style="-fx-background-color: #bdbdbd;"
                   promptText="Contraseña"/>

        <!-- Dirección -->
        <Label layoutX="115.0" layoutY="206.0" prefHeight="30.0" prefWidth="166.0"
               text="Dirección" textAlignment="CENTER">
          <font><Font size="15.0"/></font>
        </Label>
        <TextField fx:id="fieldDireccion" layoutX="107.0" layoutY="232.0"
                   prefHeight="26.0" prefWidth="183.0"
                   style="-fx-background-color: #bdbdbd;"
                   promptText="Dirección"/>

        <!-- Tipo de cliente -->
        <Label layoutX="321.0" layoutY="206.0" prefHeight="30.0" prefWidth="166.0"
               text="Plan" textAlignment="CENTER">
          <font><Font size="15.0"/></font>
        </Label>
        <MenuButton fx:id="menuTipo" layoutX="315.0" layoutY="232.0"
                    prefHeight="26.0" prefWidth="184.0" text="Seleccionar plan">
          <items>
            <MenuItem text="Estándar" onAction="#handleTipoEstandar"/>
            <MenuItem text="Premium"  onAction="#handleTipoPremium"/>
          </items>
        </MenuButton>

        <!-- Error -->
        <Label fx:id="labelError" layoutX="107.0" layoutY="265.0"
               prefWidth="386.0" textFill="RED" text=""/>

        <!-- Botones -->
        <Button layoutX="156.0" layoutY="300.0"
                prefHeight="34.0" prefWidth="131.0"
                text="Cancelar"
                onAction="#handleCancelar"/>
        <Button layoutX="310.0" layoutY="300.0"
                prefHeight="34.0" prefWidth="186.0"
                text="Registrar cuenta"
                onAction="#handleRegistrar"/>

        <Label layoutX="222.0" layoutY="345.0"
               text="¿Ya tienes cuenta? Inicia sesión"
               textFill="#241ad7"
               onMouseClicked="#handleIrALogin"
               style="-fx-cursor: hand;"/>
      </children>
    </AnchorPane>
  </content>
</TitledPane>
