<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<TitledPane animated="false"
            maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="600.0"
            text="UPB-CAC"
            fx:controller="edu.co.diegoxs96.Client.Controller.LoginViewController"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17">
  <content>
    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="380.0" prefWidth="600.0">
      <children>
        <Label layoutX="221.0" layoutY="50.0" prefHeight="30.0" prefWidth="167.0"
               text="Num identificación" textAlignment="CENTER">
          <font><Font size="20.0"/></font>
        </Label>
        <TextField fx:id="fieldIdentificacion" layoutX="142.0" layoutY="90.0"
                   prefHeight="30.0" prefWidth="325.0"
                   promptText="Número de identificación"/>

        <Label layoutX="255.0" layoutY="150.0" text="Contraseña">
          <font><Font size="20.0"/></font>
        </Label>
        <PasswordField fx:id="fieldContrasena" layoutX="142.0" layoutY="185.0"
                       prefHeight="30.0" prefWidth="326.0"
                       promptText="Contraseña"/>

        <Label fx:id="labelError" layoutX="142.0" layoutY="230.0"
               prefWidth="325.0" textFill="RED" text=""/>

        <Button fx:id="btnLogin" layoutX="216.0" layoutY="265.0"
                prefHeight="34.0" prefWidth="177.0"
                text="Iniciar sesión"
                onAction="#handleLogin"/>

        <Label layoutX="228.0" layoutY="315.0"
               text="¿No tienes cuenta? Regístrate"
               textFill="#241ad7"
               onMouseClicked="#handleIrARegistro"
               style="-fx-cursor: hand;"/>
      </children>
    </AnchorPane>
  </content>
</TitledPane>
