<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<TitledPane animated="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" text="UPB-CAC-Menu ADMIN"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.co.diegoxs96.Client.Controller.MenuAdminController">
  <content>
    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0"
                style="-fx-background-color: #bdbdbd;">
      <children>

        <!-- Sidebar -->
        <Button layoutX="14.0" layoutY="30.0"  prefHeight="30.0" prefWidth="150.0" text="Editar perfil"     mnemonicParsing="false" onAction="#handleEditarPerfil"/>
        <Button layoutX="14.0" layoutY="76.0"  prefHeight="30.0" prefWidth="150.0" text="Buscar Cliente"    mnemonicParsing="false" onAction="#handleBuscarCliente"/>
        <Button layoutX="14.0" layoutY="123.0" prefHeight="30.0" prefWidth="150.0" text="Ver cita"          mnemonicParsing="false" onAction="#handleVerCita"/>
        <Button layoutX="14.0" layoutY="171.0" prefHeight="30.0" prefWidth="150.0" text="Modificar cita"    mnemonicParsing="false" onAction="#handleModificarCita"/>
        <Button layoutX="14.0" layoutY="217.0" prefHeight="30.0" prefWidth="150.0" text="Historial de Citas" mnemonicParsing="false" onAction="#handleHistorial"/>
        <Button layoutX="14.0" layoutY="263.0" prefHeight="30.0" prefWidth="150.0" text="Menu"              mnemonicParsing="false" onAction="#handleMenu"/>

        <!-- Cerrar sesión -->
        <Label layoutX="522.0" prefHeight="17.0" prefWidth="76.0" text="Cerrar Sesion"
               textFill="#1622cf" style="-fx-cursor: hand;" onMouseClicked="#handleCerrarSesion"/>

        <!-- Panel Tiempos del Sistema -->
        <Pane layoutX="177.0" layoutY="12.0" prefHeight="336.0" prefWidth="198.0"
              style="-fx-background-color: #E6E6E6;">
          <children>
            <Pane layoutX="-1.0" prefHeight="21.0" prefWidth="214.0"
                  style="-fx-background-color: #bdbdbd;">
              <children>
                <Label layoutX="7.0" layoutY="2.0" text="Tiemos del Sistema">
                  <font><Font name="System Bold" size="12.0"/></font>
                </Label>
              </children>
            </Pane>
            <Label layoutX="22.0" layoutY="31.0" prefHeight="17.0" prefWidth="149.0"
                   text="Selecionar dias de atencion"/>
            <MenuButton fx:id="menuDias" layoutX="4.0" layoutY="48.0"
                        mnemonicParsing="false" prefHeight="25.0" prefWidth="190.0" text="Seleccione">
              <items>
                <MenuItem text="Lunes-Viernes"  onAction="#handleDiasLV"/>
                <MenuItem text="Lunes-Sabado"   onAction="#handleDiasLS"/>
                <MenuItem text="Todos los Dias" onAction="#handleDiasTodos"/>
              </items>
            </MenuButton>
            <Label layoutX="4.0" layoutY="81.0"  prefHeight="17.0" prefWidth="192.0" text="Tiempo max de atencion por banco"/>
            <TextField fx:id="fieldTiempoAtencion" layoutX="5.0" layoutY="106.0"
                       prefHeight="25.0" prefWidth="191.0"/>
            <Label layoutX="5.0" layoutY="138.0" prefHeight="17.0" prefWidth="192.0" text="Tiempo de Vencimiento de ticket"/>
            <TextField fx:id="fieldTiempoVencimiento" layoutX="4.0" layoutY="155.0"
                       prefHeight="25.0" prefWidth="191.0"/>
            <Label layoutX="23.0" layoutY="189.0" prefHeight="17.0" prefWidth="148.0" text="cerrar sesion inactiva desde"/>
            <TextField fx:id="fieldSesionInactiva" layoutX="4.0" layoutY="214.0"
                       prefHeight="25.0" prefWidth="191.0"/>
          </children>
        </Pane>

        <!-- Panel Capacidad de Colas -->
        <Pane layoutX="386.0" layoutY="12.0" prefHeight="336.0" prefWidth="198.0"
              style="-fx-background-color: #E6E6E6;">
          <children>
            <Pane layoutX="-2.0" prefHeight="21.0" prefWidth="206.0"
                  style="-fx-background-color: #bdbdbd;">
              <children>
                <Label layoutX="7.0" layoutY="2.0" text="Capacidad de colas">
                  <font><Font name="System Bold" size="12.0"/></font>
                </Label>
              </children>
            </Pane>
            <Label layoutX="5.0"  layoutY="35.0"  prefHeight="17.0" prefWidth="192.0" text="Capacidad Max de Colas por Banco"/>
            <TextField fx:id="fieldCapacidadCola" layoutX="6.0" layoutY="52.0"
                       prefHeight="25.0" prefWidth="191.0"/>
            <Label layoutX="21.0" layoutY="87.0"  prefHeight="17.0" prefWidth="156.0" text="maximo de sesiones abiertas"/>
            <TextField fx:id="fieldMaxSesiones" layoutX="4.0" layoutY="107.0"
                       prefHeight="25.0" prefWidth="191.0"/>
            <Button layoutX="50.0" layoutY="250.0" prefHeight="34.0" prefWidth="91.0"
                    text="Guardar" mnemonicParsing="false" onAction="#handleGuardar"/>
          </children>
        </Pane>

      </children>
    </AnchorPane>
  </content>
</TitledPane>
