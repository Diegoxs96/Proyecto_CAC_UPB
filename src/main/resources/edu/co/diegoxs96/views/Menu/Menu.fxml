<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<TitledPane animated="false"
            maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="600.0"
            text="UPB-CAC — Menú"
            fx:controller="edu.co.diegoxs96.Client.Controller.MenuController"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17">
  <content>
    <AnchorPane minHeight="0.0" minWidth="0.0"
                prefHeight="380.0" prefWidth="600.0"
                style="-fx-background-color: #bdbdbd;">
      <children>
        <Button layoutX="14.0" layoutY="7.0"   prefHeight="30.0" prefWidth="138.0" text="Editar perfil"          onAction="#handleEditarPerfil"/>
        <Button layoutX="14.0" layoutY="43.0"  prefHeight="30.0" prefWidth="138.0" text="Solicitar Cita"         onAction="#handleSolicitarCita"/>
        <Button layoutX="14.0" layoutY="80.0"  prefHeight="30.0" prefWidth="138.0" text="Ver cita"               onAction="#handleVerCita"/>
        <Button layoutX="14.0" layoutY="117.0" prefHeight="30.0" prefWidth="138.0" text="Modificar cita"         onAction="#handleModificarCita"/>
        <Button layoutX="14.0" layoutY="154.0" prefHeight="30.0" prefWidth="138.0" text="Obtener ticket virtual" onAction="#handleObtenerTicket"/>
        <Button layoutX="14.0" layoutY="191.0" prefHeight="30.0" prefWidth="138.0" text="Notificación de turno"  onAction="#handleNotificacion"/>
        <Button layoutX="14.0" layoutY="228.0" prefHeight="30.0" prefWidth="138.0" text="Consultar turno"        onAction="#handleConsultarTurno"/>
        <Button layoutX="14.0" layoutY="264.0" prefHeight="30.0" prefWidth="138.0" text="Historial de citas"     onAction="#handleHistorial"/>
        <Button layoutX="14.0" layoutY="301.0" prefHeight="30.0" prefWidth="140.0" text="Cancelar cita"          onAction="#handleCancelarCita"/>
        <Button layoutX="14.0" layoutY="337.0" prefHeight="30.0" prefWidth="138.0" text="Solicitar consulta"     onAction="#handleSolicitarConsulta"/>

        <!-- Imagen desde resources (funciona en cualquier computador) -->
        <ImageView fx:id="imgMenu" fitHeight="267.0" fitWidth="410.0"
                   layoutX="171.0" layoutY="16.0"
                   pickOnBounds="true" preserveRatio="true">
          <image>
            <Image url="@/edu/co/diegoxs96/images/menu_imagen.jpg"
                   onError="edu.co.diegoxs96.Client.Controller.MenuController.imagenNoDisponible"/>
          </image>
        </ImageView>

        <Label layoutX="171.0" layoutY="294.0" prefHeight="36.0" prefWidth="410.0"
               text="Una usuaria feliz gracias a este super servicio">
          <font><Font size="21.0"/></font>
        </Label>
      </children>
    </AnchorPane>
  </content>
</TitledPane>
