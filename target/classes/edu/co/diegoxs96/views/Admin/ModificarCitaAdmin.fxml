<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<TitledPane animated="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="500.0" prefWidth="650.0"
            text="UPB-CAC- Modificar cita Admin"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.co.diegoxs96.Client.Controller.ModificarCitaAdminController">
  <content>
    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="460.0" prefWidth="650.0"
                style="-fx-background-color: #bdbdbd;">
      <children>

        <!-- Sidebar -->
        <Button layoutX="14.0" layoutY="29.0"  prefHeight="36.0" prefWidth="126.0" text="Editar Perfil"   mnemonicParsing="false" onAction="#handleEditarPerfil"/>
        <Button layoutX="14.0" layoutY="80.0"  prefHeight="36.0" prefWidth="126.0" text="Buscar Cliente"  mnemonicParsing="false" onAction="#handleBuscarCliente"/>
        <Button layoutX="14.0" layoutY="130.0" prefHeight="36.0" prefWidth="126.0" text="Ver Cita"        mnemonicParsing="false" onAction="#handleVerCita"/>
        <Button layoutX="14.0" layoutY="178.0" prefHeight="36.0" prefWidth="126.0" text="Modificar Cita"  mnemonicParsing="false" onAction="#handleModificarCita"/>
        <Button layoutX="14.0" layoutY="225.0" prefHeight="36.0" prefWidth="126.0" text="Historial Cita"  mnemonicParsing="false" onAction="#handleHistorial"/>
        <Button layoutX="14.0" layoutY="275.0" prefHeight="36.0" prefWidth="126.0" text="Menu"            mnemonicParsing="false" onAction="#handleMenu"/>

        <!-- Panel derecho -->
        <Pane layoutX="152.0" layoutY="10.0" prefHeight="440.0" prefWidth="486.0"
              style="-fx-background-color: #E6E6E6;">
          <children>

            <!-- Tabla de todas las citas -->
            <Label layoutX="10.0" layoutY="8.0" text="Selecciona la cita a modificar:">
              <font><Font name="System Bold" size="12.0"/></font>
            </Label>
            <TableView fx:id="tablaCitas" layoutX="10.0" layoutY="28.0"
                       prefHeight="130.0" prefWidth="465.0">
              <columns>
                <TableColumn fx:id="colId"      prefWidth="45.0"  text="ID"/>
                <TableColumn fx:id="colCliente" prefWidth="100.0" text="Cliente"/>
                <TableColumn fx:id="colTipoT"   prefWidth="80.0"  text="Tipo"/>
                <TableColumn fx:id="colFechaT"  prefWidth="75.0"  text="Fecha"/>
                <TableColumn fx:id="colHoraT"   prefWidth="55.0"  text="Hora"/>
                <TableColumn fx:id="colEstadoT" prefWidth="70.0"  text="Estado"/>
              </columns>
            </TableView>

            <!-- Formulario -->
            <Label layoutX="10.0" layoutY="168.0" text="Tipo de cita"/>
            <MenuButton fx:id="menuTipoCita" layoutX="10.0" layoutY="186.0"
                        mnemonicParsing="false" prefHeight="26.0" prefWidth="198.0" text="Seleccione">
              <items>
                <MenuItem text="Asesoría"   onAction="#handleTipoAsesoria"/>
                <MenuItem text="Reclamo"    onAction="#handleTipoReclamo"/>
                <MenuItem text="Devolución" onAction="#handleTipoDevolucion"/>
              </items>
            </MenuButton>

            <Label layoutX="10.0" layoutY="222.0" text="Fecha DD/MM/AAAA"/>
            <TextField fx:id="fieldFecha" layoutX="10.0" layoutY="240.0"
                       prefHeight="26.0" prefWidth="198.0"/>

            <Label layoutX="10.0" layoutY="275.0" text="Hora"/>
            <MenuButton fx:id="menuHora" layoutX="10.0" layoutY="293.0"
                        mnemonicParsing="false" prefHeight="26.0" prefWidth="198.0" text="Seleccione">
              <items>
                <MenuItem text="7AM"  onAction="#handleHora"/>
                <MenuItem text="8AM"  onAction="#handleHora"/>
                <MenuItem text="9AM"  onAction="#handleHora"/>
                <MenuItem text="10AM" onAction="#handleHora"/>
                <MenuItem text="11AM" onAction="#handleHora"/>
                <MenuItem text="12PM" onAction="#handleHora"/>
                <MenuItem text="1PM"  onAction="#handleHora"/>
                <MenuItem text="2PM"  onAction="#handleHora"/>
                <MenuItem text="3PM"  onAction="#handleHora"/>
                <MenuItem text="4PM"  onAction="#handleHora"/>
                <MenuItem text="5PM"  onAction="#handleHora"/>
                <MenuItem text="6PM"  onAction="#handleHora"/>
              </items>
            </MenuButton>

            <Label layoutX="230.0" layoutY="168.0" text="Motivo de la cita"/>
            <TextField fx:id="fieldMotivo" layoutX="230.0" layoutY="186.0"
                       prefHeight="133.0" prefWidth="240.0"/>

            <Label fx:id="labelMensaje" layoutX="10.0" layoutY="332.0"
                   prefHeight="18.0" prefWidth="465.0"/>

            <Button layoutX="160.0" layoutY="360.0" prefHeight="36.0" prefWidth="92.0"
                    text="Guardar" mnemonicParsing="false" onAction="#handleGuardar"/>
            <Button layoutX="270.0" layoutY="360.0" prefHeight="36.0" prefWidth="92.0"
                    text="Cancelar Cita" mnemonicParsing="false" onAction="#handleCancelarCita"/>

          </children>
        </Pane>

      </children>
    </AnchorPane>
  </content>
</TitledPane>
