<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<TitledPane animated="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0"
            text="UPB-CAC-Buscar Cliente Admin"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.co.diegoxs96.Client.Controller.BuscarClienteController">
  <content>
    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0"
                style="-fx-background-color: #bdbdbd;">
      <children>

        <!-- Sidebar -->
        <Button layoutX="14.0" layoutY="14.0"  prefHeight="30.0" prefWidth="150.0" text="Editar perfil"    mnemonicParsing="false" onAction="#handleEditarPerfil"/>
        <Button layoutX="14.0" layoutY="64.0"  prefHeight="30.0" prefWidth="150.0" text="Buscar Cliente"   mnemonicParsing="false" onAction="#handleBuscarCliente"/>
        <Button layoutX="14.0" layoutY="113.0" prefHeight="30.0" prefWidth="150.0" text="Ver cita"         mnemonicParsing="false" onAction="#handleVerCita"/>
        <Button layoutX="14.0" layoutY="165.0" prefHeight="30.0" prefWidth="150.0" text="Modificar cita"   mnemonicParsing="false" onAction="#handleModificarCita"/>
        <Button layoutX="14.0" layoutY="222.0" prefHeight="30.0" prefWidth="150.0" text="Historial de Citas" mnemonicParsing="false" onAction="#handleHistorial"/>
        <Button layoutX="14.0" layoutY="276.0" prefHeight="30.0" prefWidth="150.0" text="Menu"             mnemonicParsing="false" onAction="#handleMenu"/>

        <!-- Panel derecho -->
        <Pane layoutX="188.0" layoutY="12.0" prefHeight="336.0" prefWidth="394.0"
              style="-fx-background-color: #E6E6E6;">
          <children>
            <Label layoutX="56.0" layoutY="28.0" text="Buscar Cliente"/>

            <Pane layoutX="56.0" layoutY="77.0" prefHeight="21.0" prefWidth="282.0"
                  style="-fx-background-color: #bdbdbd;">
              <children>
                <Label layoutX="7.0" layoutY="2.0" text="Ingresar ID"/>
              </children>
            </Pane>
            <TextField fx:id="fieldBuscarId" layoutX="56.0" layoutY="45.0"
                       prefHeight="25.0" prefWidth="282.0"/>

            <Label layoutX="61.0" layoutY="102.0" text="Num de Cita"/>
            <Pane layoutX="57.0" layoutY="149.0" prefHeight="21.0" prefWidth="281.0"
                  style="-fx-background-color: #bdbdbd;">
              <children>
                <Label layoutX="10.0" layoutY="2.0" text="Num de Cita"/>
              </children>
            </Pane>
            <TextField fx:id="fieldNumeroCita" layoutX="56.0" layoutY="119.0"
                       prefHeight="25.0" prefWidth="282.0"/>

            <Label layoutX="63.0" layoutY="174.0" text="Prioridad de la Cita"/>
            <MenuButton fx:id="menuPrioridad" layoutX="59.0" layoutY="191.0"
                        mnemonicParsing="false" prefHeight="25.0" prefWidth="279.0" text="Seleccione">
              <items>
                <MenuItem text="Estándar" onAction="#handlePrioridadEstandar"/>
                <MenuItem text="Premium"  onAction="#handlePrioridadPremium"/>
              </items>
            </MenuButton>

            <Pane layoutX="63.0" layoutY="223.0" prefHeight="36.0" prefWidth="271.0"
                  style="-fx-background-color: #bdbdbd;">
              <children>
                <Label layoutX="7.0" layoutY="7.0" prefHeight="25.0" prefWidth="264.0"
                       text="Solo aplica a Ticket aun no llamados">
                  <font><Font size="16.0"/></font>
                </Label>
              </children>
            </Pane>

            <Label fx:id="labelResultado" layoutX="56.0" layoutY="268.0"
                   prefHeight="25.0" prefWidth="282.0"/>

            <Button layoutX="172.0" layoutY="300.0" mnemonicParsing="false"
                    text="Buscar" onAction="#handleBuscar"/>
          </children>
        </Pane>

      </children>
    </AnchorPane>
  </content>
</TitledPane>
