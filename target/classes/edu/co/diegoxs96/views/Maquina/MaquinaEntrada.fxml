<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<TitledPane animated="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0"
            text="UPB-CAC-Maquina de Entrada"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.co.diegoxs96.Client.Controller.MaquinaEntradaViewController">
  <content>
    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0"
                style="-fx-background-color: #bdbdbd;">
      <children>

        <Label layoutX="523.0" layoutY="5.0" text="Cerrar Sesion" textFill="#241ad7"
               style="-fx-cursor: hand;" onMouseClicked="#handleCerrarSesion"/>

        <Pane layoutX="91.0" layoutY="31.0" prefHeight="320.0" prefWidth="415.0"
              style="-fx-background-color: white;">
          <children>
            <Label layoutX="22.0" layoutY="14.0" prefHeight="30.0" prefWidth="371.0"
                   text="Ingrese los datos para obtener su turno" textAlignment="CENTER">
              <font><Font name="System Bold" size="20.0"/></font>
            </Label>
            <Label layoutX="57.0" layoutY="44.0" prefHeight="22.0" prefWidth="302.0"
                   text="El sistema validara la Cita y Asignara el banco" textAlignment="CENTER">
              <font><Font size="15.0"/></font>
            </Label>

            <Label layoutX="57.0" layoutY="90.0" prefHeight="22.0" prefWidth="142.0"
                   text="Num Identificacion" textAlignment="CENTER">
              <font><Font size="15.0"/></font>
            </Label>
            <TextField fx:id="fieldIdentificacion" layoutX="45.0" layoutY="112.0"
                       prefHeight="26.0" prefWidth="325.0"/>

            <Label layoutX="57.0" layoutY="157.0" prefHeight="22.0" prefWidth="86.0"
                   text="Num de Cita" textAlignment="CENTER">
              <font><Font size="15.0"/></font>
            </Label>
            <TextField fx:id="fieldNumeroCita" layoutX="45.0" layoutY="179.0"
                       prefHeight="26.0" prefWidth="325.0"/>

            <Label fx:id="labelResultado" layoutX="45.0" layoutY="218.0"
                   prefHeight="22.0" prefWidth="325.0" textAlignment="CENTER"/>

            <Label fx:id="labelTurno" layoutX="100.0" layoutY="248.0"
                   prefHeight="30.0" prefWidth="215.0" textAlignment="CENTER"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;"/>

            <Button layoutX="136.0" layoutY="282.0" mnemonicParsing="false"
                    prefHeight="34.0" prefWidth="143.0" text="Siguiente"
                    onAction="#handleSiguiente"/>
          </children>
        </Pane>

      </children>
    </AnchorPane>
  </content>
</TitledPane>
