<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<TitledPane animated="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0"
            text="UPB-CAC- Consultar Turno Cliente"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.co.diegoxs96.Client.Controller.ConsultarTurnoController">
  <content>
    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="391.0" prefWidth="482.0">
      <children>

        <!-- Sidebar -->
        <Button layoutX="14.0" layoutY="24.0"  prefHeight="35.0" prefWidth="134.0" text="Editar Perfil"    mnemonicParsing="false" onAction="#handleEditarPerfil"/>
        <Button layoutX="14.0" layoutY="70.0"  prefHeight="35.0" prefWidth="134.0" text="Solicitar Cita"   mnemonicParsing="false" onAction="#handleSolicitarCita"/>
        <Button layoutX="14.0" layoutY="116.0" prefHeight="35.0" prefWidth="134.0" text="Ver Cita"         mnemonicParsing="false" onAction="#handleVerCita"/>
        <Button layoutX="14.0" layoutY="161.0" prefHeight="35.0" prefWidth="134.0" text="Modificar Cita"   mnemonicParsing="false" onAction="#handleModificarCita"/>
        <Button layoutX="14.0" layoutY="207.0" prefHeight="35.0" prefWidth="134.0" text="Consultar Turno"  mnemonicParsing="false" onAction="#handleConsultarTurno"/>
        <Button layoutX="14.0" layoutY="253.0" prefHeight="35.0" prefWidth="134.0" text="Historial de Cita" mnemonicParsing="false" onAction="#handleHistorial"/>
        <Button layoutX="14.0" layoutY="301.0" prefHeight="35.0" prefWidth="134.0" text="Cancelar Cita"    mnemonicParsing="false" onAction="#handleCancelarCita"/>

        <!-- Panel formulario -->
        <Pane layoutX="158.0" layoutY="11.0" prefHeight="350.0" prefWidth="282.0"
              style="-fx-background-color: #bdbdbd;">
          <children>
            <Label layoutX="29.0"  layoutY="74.0"  text="Num de Identificacion"/>
            <TextField fx:id="fieldIdentificacion" layoutX="30.0" layoutY="92.0"
                       prefHeight="26.0" prefWidth="226.0"/>
            <Label layoutX="28.0"  layoutY="145.0" text="Num de Cita"/>
            <TextField fx:id="fieldNumeroCita" layoutX="28.0" layoutY="163.0"
                       prefHeight="26.0" prefWidth="226.0"/>
            <Button layoutX="96.0" layoutY="232.0" prefHeight="36.0" prefWidth="92.0"
                    text="Buscar Turno" mnemonicParsing="false" onAction="#handleBuscar"/>
          </children>
        </Pane>

        <!-- Panel turno -->
        <Pane layoutX="444.0" layoutY="11.0" prefHeight="351.0" prefWidth="146.0"
              style="-fx-background-color: #bdbdbd;">
          <children>
            <Label layoutX="31.0" layoutY="32.0" prefHeight="36.0" prefWidth="85.0" text="TURNO">
              <font><Font name="System Bold" size="23.0"/></font>
            </Label>
            <Pane layoutX="5.0" layoutY="97.0" prefHeight="243.0" prefWidth="137.0"
                  style="-fx-background-color: #E6E6E6;">
              <children>
                <Label layoutX="3.0" layoutY="14.0" prefHeight="54.0" prefWidth="132.0"
                       text="Numero de Espera">
                  <font><Font name="System Bold" size="15.0"/></font>
                </Label>
                <Label fx:id="labelPosicion" layoutX="24.0" layoutY="68.0"
                       prefHeight="18.0" prefWidth="99.0" text="Num:-"/>
              </children>
            </Pane>
          </children>
        </Pane>

      </children>
    </AnchorPane>
  </content>
</TitledPane>
